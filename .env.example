APP_KEY=replace-with-a-long-random-secret
# Leave empty when deployed at the domain root. Example: /badomen
APP_BASE_PATH=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=badomen
DB_USER=badomen
DB_PASSWORD=replace-me
DB_CONNECT_TIMEOUT=5
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret
GMAIL_REFRESH_TOKEN=your-offline-refresh-token
GMAIL_SENDER_EMAIL=your-sender@gmail.com
GMAIL_SENDER_NAME=Badomen
# Alternative to Gmail API OAuth: Google App Password for SMTP.
GMAIL_APP_PASSWORD=your-16-character-app-password
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
